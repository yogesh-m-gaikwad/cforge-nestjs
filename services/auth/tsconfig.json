{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2021",

    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,

    "outDir": "./dist",
    "rootDir": "./src",

    "useDefineForClassFields": false
  },
  "include": ["src"]
}
